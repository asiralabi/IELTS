# Environment / secrets
.env
.env.local
.env.*.local

# Local Claude Code config & memory (not for a shared repo)
.claude/

# Internal security note (references the API key prefix)
SECURITY_NOTICE.md

# Root-level runtime data (e.g. stray sqlite from a wrong-cwd launch)
/data/

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.eggs/
.coverage
htmlcov/
.venv/
venv/
env/

# Node / Next.js (also covered by frontend/.gitignore)
node_modules/
.next/
out/
build/
dist/

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/

# Logs / scratch
*.log
