# AI IELTS Instructor & Examiner - environment configuration
# Copy to .env and adjust values. All variables are optional; defaults shown.

# --- Application ---
APP_NAME="AI IELTS Instructor & Examiner"
DEBUG=false

# --- Database ---
DATABASE_URL=sqlite:///./data/ielts.db

# --- Auth / JWT ---
# Generate a strong secret, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- LLM provider: ollama | anthropic | openai ---
LLM_PROVIDER=ollama

# Ollama (local, default)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

# Anthropic (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI or OpenAI-compatible endpoint (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Generation parameters
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=2048
# Per-request timeout in seconds (local CPU inference can be slow)
LLM_TIMEOUT=600

# --- Storage paths ---
DATA_DIR=./data
UPLOAD_DIR=./data/uploads

# --- Qdrant vector store ---
# Embedded (local path) is used unless QDRANT_URL is set to a remote instance
QDRANT_PATH=./data/qdrant
QDRANT_URL=
QDRANT_COLLECTION=ielts_knowledge

# --- RAG ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Chunk size/overlap are approximate token counts (word-based)
RAG_CHUNK_SIZE=650
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=5
