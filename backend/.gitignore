# they clone straight into Kaggle for the QLoRA notebooks.
data/*
!data/datasets/
data/datasets/*
!data/datasets/*.jsonl

# Source material: huge + copyrighted Cambridge PDFs, audio CDs, screen
# recordings. Grounding/training input only — never published (north-star).
books/
Audios/

# Browser-verification screenshot artifacts (regenerated by tools/browser_*.py)
tools/browser_shots/

